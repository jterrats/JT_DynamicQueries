/**
 * @description Controller for managing JT_PersonaConfig__mdt records via LWC
 * @author Jaime Terrats
 * @group Dynamic Queries
 * @last modified on 04-26-2026
 * @last modified by Jaime Terrats
 **/
@SuppressWarnings('PMD.AvoidDebugStatements')
public with sharing class JT_PersonaConfigController {
  // ─── Inner classes ──────────────────────────────────────────────────────────

  /**
   * @description Result wrapper for save/delete operations
   **/
  public class PersonaConfigResult {
    @AuraEnabled
    public Boolean success;
    @AuraEnabled
    public String deploymentId;
    @AuraEnabled
    public String errorMessage;
  }

  /**
   * @description Represents a single JT_PersonaConfig__mdt record
   **/
  public class PersonaConfigRecord {
    @AuraEnabled
    public String developerName;
    @AuraEnabled
    public String label;
    @AuraEnabled
    public String profileApiName;
    @AuraEnabled
    public String permissionSets;
    @AuraEnabled
    public Boolean seeAllData;
    @AuraEnabled
    public String description;
  }

  /**
   * @description Option wrapper for Profile picklist
   **/
  public class ProfileOption {
    @AuraEnabled
    public String value;
    @AuraEnabled
    public String label;
  }

  /**
   * @description Option wrapper for PermissionSet picklist
   **/
  public class PermissionSetOption {
    @AuraEnabled
    public String value;
    @AuraEnabled
    public String label;
  }

  // ─── AuraEnabled methods ─────────────────────────────────────────────────────

  /**
   * @description Returns all JT_PersonaConfig__mdt records
   * @author Jaime Terrats | 04-26-2026
   * @return List<PersonaConfigRecord>
   **/
  @AuraEnabled(cacheable=true)
  public static List<PersonaConfigRecord> getPersonaConfigs() {
    try {
      List<JT_PersonaConfig__mdt> records = [
        SELECT
          DeveloperName,
          Label,
          Profile_API_Name__c,
          Permission_Sets__c,
          See_All_Data__c,
          Description__c
        FROM JT_PersonaConfig__mdt
        WITH USER_MODE
        ORDER BY Label
      ];

      List<PersonaConfigRecord> results = new List<PersonaConfigRecord>();
      for (JT_PersonaConfig__mdt rec : records) {
        PersonaConfigRecord dto = new PersonaConfigRecord();
        dto.developerName = rec.DeveloperName;
        dto.label = rec.Label;
        dto.profileApiName = rec.Profile_API_Name__c;
        dto.permissionSets = rec.Permission_Sets__c;
        dto.seeAllData = rec.See_All_Data__c;
        dto.description = rec.Description__c;
        results.add(dto);
      }
      return results;
    } catch (Exception e) {
      System.debug(
        LoggingLevel.ERROR,
        'JT_PersonaConfigController.getPersonaConfigs error: ' + e.getMessage()
      );
      throw new AuraHandledException(e.getMessage());
    }
  }

  /**
   * @description Returns all Profiles as picklist options
   * @author Jaime Terrats | 04-26-2026
   * @return List<ProfileOption>
   **/
  @AuraEnabled(cacheable=true)
  public static List<ProfileOption> getProfiles() {
    try {
      List<Profile> profiles = [
        SELECT Id, Name
        FROM Profile
        WITH USER_MODE
        ORDER BY Name
      ];

      List<ProfileOption> options = new List<ProfileOption>();
      for (Profile p : profiles) {
        ProfileOption opt = new ProfileOption();
        opt.value = p.Name;
        opt.label = p.Name;
        options.add(opt);
      }
      return options;
    } catch (Exception e) {
      System.debug(
        LoggingLevel.ERROR,
        'JT_PersonaConfigController.getProfiles error: ' + e.getMessage()
      );
      throw new AuraHandledException(e.getMessage());
    }
  }

  /**
   * @description Returns all custom PermissionSets and PermissionSetGroups as picklist options.
   * PSG entries are prefixed with "[PSG] " in the label to distinguish them from regular PS entries.
   * @author Jaime Terrats | 04-26-2026
   * @return List<PermissionSetOption>
   **/
  @AuraEnabled(cacheable=true)
  public static List<PermissionSetOption> getPermissionSets() {
    try {
      List<PermissionSetOption> options = new List<PermissionSetOption>();

      // Permission Sets — exclude profile-owned (autogenerated, show as IDs)
      for (PermissionSet ps : [
        SELECT Id, Name, Label
        FROM PermissionSet
        WHERE IsOwnedByProfile = FALSE
        WITH USER_MODE
        ORDER BY Label
      ]) {
        PermissionSetOption opt = new PermissionSetOption();
        opt.value = ps.Name;
        opt.label = String.isNotBlank(ps.Label) ? ps.Label : ps.Name;
        options.add(opt);
      }

      // Permission Set Groups
      for (PermissionSetGroup psg : [
        SELECT Id, DeveloperName, MasterLabel
        FROM PermissionSetGroup
        WITH USER_MODE
        ORDER BY MasterLabel
      ]) {
        PermissionSetOption opt = new PermissionSetOption();
        opt.value = psg.DeveloperName;
        opt.label =
          '[PSG] ' +
          (String.isNotBlank(psg.MasterLabel)
            ? psg.MasterLabel
            : psg.DeveloperName);
        options.add(opt);
      }

      return options;
    } catch (Exception e) {
      System.debug(
        LoggingLevel.ERROR,
        'JT_PersonaConfigController.getPermissionSets error: ' + e.getMessage()
      );
      throw new AuraHandledException(e.getMessage());
    }
  }

  /**
   * @description Saves (upserts) a JT_PersonaConfig__mdt record via Metadata API
   * @author Jaime Terrats | 04-26-2026
   * @param configJson JSON-serialized PersonaConfigRecord fields
   * @return PersonaConfigResult
   **/
  @AuraEnabled
  public static PersonaConfigResult savePersonaConfig(String configJson) {
    PersonaConfigResult result = new PersonaConfigResult();
    result.success = false;

    try {
      if (String.isBlank(configJson)) {
        result.errorMessage = 'configJson is required.';
        return result;
      }

      Map<String, Object> configMap = (Map<String, Object>) JSON.deserializeUntyped(
        configJson
      );

      String developerName = configMap.get('developerName') != null
        ? String.valueOf(configMap.get('developerName'))
        : null;
      String recordLabel = configMap.get('label') != null
        ? String.valueOf(configMap.get('label'))
        : null;

      if (String.isBlank(developerName) || String.isBlank(recordLabel)) {
        result.errorMessage = 'developerName and label are required.';
        return result;
      }

      String profileApiName = configMap.get('profileApiName') != null
        ? String.valueOf(configMap.get('profileApiName'))
        : null;
      String permissionSets = configMap.get('permissionSets') != null
        ? String.valueOf(configMap.get('permissionSets'))
        : null;
      Object seeAllDataObj = configMap.get('seeAllData');
      Boolean seeAllData = seeAllDataObj instanceof Boolean
        ? (Boolean) seeAllDataObj
        : (seeAllDataObj != null
            ? Boolean.valueOf(String.valueOf(seeAllDataObj))
            : false);
      String description = configMap.get('description') != null
        ? String.valueOf(configMap.get('description'))
        : null;

      // Build CustomMetadata record
      Metadata.CustomMetadata customMetadata = new Metadata.CustomMetadata();
      customMetadata.fullName = 'JT_PersonaConfig__mdt.' + developerName;
      customMetadata.label = recordLabel;

      customMetadata.values.add(
        buildFieldValue('Profile_API_Name__c', profileApiName)
      );
      customMetadata.values.add(
        buildFieldValue('Permission_Sets__c', permissionSets)
      );
      customMetadata.values.add(buildFieldValue('See_All_Data__c', seeAllData));
      customMetadata.values.add(buildFieldValue('Description__c', description));

      Metadata.DeployContainer mdContainer = new Metadata.DeployContainer();
      mdContainer.addMetadata(customMetadata);

      Id deployRequestId = Metadata.Operations.enqueueDeployment(
        mdContainer,
        new JT_MetadataDeployCallback()
      );

      result.success = true;
      result.deploymentId = deployRequestId;
      return result;
    } catch (Exception e) {
      System.debug(
        LoggingLevel.ERROR,
        'JT_PersonaConfigController.savePersonaConfig error: ' + e.getMessage()
      );
      result.success = false;
      result.errorMessage = e.getMessage();
      return result;
    }
  }

  /**
   * @description Deletion of CMT records via Metadata API is not supported.
   * Records must be deleted manually from Setup > Custom Metadata Types.
   * @author Jaime Terrats | 04-26-2026
   * @param developerName Developer name of the record to delete
   * @return PersonaConfigResult with success=false and a guidance message
   **/
  @AuraEnabled
  public static PersonaConfigResult deletePersonaConfig(String developerName) {
    PersonaConfigResult result = new PersonaConfigResult();
    result.success = false;
    result.errorMessage =
      'CMT records cannot be deleted via Metadata API. ' +
      'Please delete from Setup > Custom Metadata Types > JT Persona Config.';
    return result;
  }

  // ─── Private helpers ─────────────────────────────────────────────────────────

  /**
   * @description Builds a Metadata.CustomMetadataValue for a given field and value
   * @param fieldName API name of the field
   * @param fieldValue Value to assign
   * @return Metadata.CustomMetadataValue
   **/
  private static Metadata.CustomMetadataValue buildFieldValue(
    String fieldName,
    Object fieldValue
  ) {
    Metadata.CustomMetadataValue cmv = new Metadata.CustomMetadataValue();
    cmv.field = fieldName;
    cmv.value = fieldValue;
    return cmv;
  }
}
